{
    "$schema": "https://biomejs.dev/schemas/2.5.1/schema.json",
    "vcs": {
        "enabled": true,
        "clientKind": "git",
        "useIgnoreFile": true
    },
    "files": {
        "ignoreUnknown": false,
        "includes": ["**", "!**/static", "!**/*.css"]
    },
    "formatter": {
        "enabled": true,
        "indentStyle": "space",
        "indentWidth": 4,
        "lineWidth": 100
    },
    "linter": {
        "enabled": true,
        "rules": {
            "preset": "recommended",
            "a11y": "off",
            "correctness": {
                "noUnusedVariables": "off",
                "noUnusedFunctionParameters": "off",
                "useParseIntRadix": "off"
            },
            "style": {
                "noNonNullAssertion": "off",
                "useTemplate": "off"
            },
            "suspicious": {
                "noConsole": "off",
                "noExplicitAny": "off",
                "noGlobalAssign": "off",
                "noTemplateCurlyInString": "off",
                "useIterableCallbackReturn": "off"
            },
            "complexity": {
                "noExcessiveCognitiveComplexity": "off",
                "useMaxParams": {
                    "level": "warn",
                    "options": {
                        "max": 4
                    }
                }
            }
        }
    },
    "javascript": {
        "formatter": {
            "quoteStyle": "single",
            "semicolons": "asNeeded",
            "trailingCommas": "none"
        }
    },
    "html": {
        "experimentalFullSupportEnabled": true
    },
    "assist": {
        "enabled": true,
        "actions": {
            "source": {
                "organizeImports": "off"
            }
        }
    }
}
