{
    "extends": "./.svelte-kit/tsconfig.json",
    "include": ["src/**/*.ts", "src/**/*.d.ts", "src/**/*.svelte", "scripts/**/*.ts"],
    "compilerOptions": {
        "allowJs": true,
        "checkJs": true,
        "forceConsistentCasingInFileNames": true,
        "resolveJsonModule": true,
        "skipLibCheck": true,
        "sourceMap": true,
        "strict": true,
        "types": ["node"],
        "module": "NodeNext",
        "moduleResolution": "NodeNext"
    }
}
